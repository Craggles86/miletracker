{
  "expo": {
    "name": "Miletracker",
    "slug": "miletracker",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "fastshot",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "config": {
        "googleMapsApiKey": "AIzaSyAHOxVHet_aTtkvyTS1V-QXFfkNNP0FiPs"
      },
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "MileageTrack uses your location to log your trips while the app is open.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "MileageTrack uses your location in the background to automatically detect and log your trips.",
        "NSLocationAlwaysUsageDescription": "MileageTrack uses your location in the background to automatically detect and log your trips.",
        "UIBackgroundModes": [
          "location",
          "fetch"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.craggles.miletracker",
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyBNaUHLFvZTgSS7f8l2_C8QbxMxYRubYYA"
        }
      },
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_LOCATION",
        "POST_NOTIFICATIONS",
        "WAKE_LOCK"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "MileageTrack uses your location to log your trips while the app is open.",
          "locationAlwaysAndWhenInUsePermission": "MileageTrack uses your location in the background to automatically detect and log your trips.",
          "locationAlwaysPermission": "MileageTrack uses your location in the background to automatically detect and log your trips.",
          "isAndroidBackgroundLocationEnabled": true
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#ffffff"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "baseUrl": "/ecb0b3ff-c226-4b2e-96d9-32f69117089b/dev-preview/"
    },
    "owner": "craggles_86",
    "extra": {
      "googleMapsApiKey": "AIzaSyBNaUHLFvZTgSS7f8l2_C8QbxMxYRubYYA",
      "router": {},
      "eas": {
        "projectId": "8c311382-907c-4530-9fb3-84a3f0d8c38c"
      }
    }
  }
}
